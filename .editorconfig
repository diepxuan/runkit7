; 4 space indentation (no size specified)
[*]
charset = utf-8
end_of_line = lf
indent_style = space
indent_size = 4
end_of_line = lf
charset = utf-8
trim_trailing_whitespace = true
insert_final_newline = true

[*.{yml,yaml,json}]
indent_size = 2

[*.phpt]
indent_style = space
[*.xml]
indent_size = 1
indent_style = space
[*.w32]
charset = utf-8
end_of_line = crlf
indent_style = space
indent_size = 4
